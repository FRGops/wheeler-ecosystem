        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${DS_PROMETHEUS}"
            },
            "editorMode": "code",
            "expr": "histogram_quantile(0.50, sum(rate(traefik_router_request_duration_seconds_bucket{router=~\"ravynai.*\"}[5m])) by (le))",
            "legendFormat": "p50",
            "range": true,
            "refId": "A"
          },
          {
            "datasource": {
              "type": "prometheus",
