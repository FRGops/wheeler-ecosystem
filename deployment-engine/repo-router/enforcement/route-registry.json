  "route_groups": {
    "aiops": {
      "description": "AI Ops internal routes (127.0.0.1 bound)",
      "routes": [
        "surplusai-portal", "surplusai-api",
        "private-ai-gateway", "private-ai-admin", "private-ai-inference",
        "prediction-radar", "prediction-radar-ui",
        "healthchecks-dashboard", "healthchecks-api",
        "changedetection", "langflow", "langflow-api",
        "n8n", "n8n-editor",
        "grafana", "prometheus", "alertmanager", "loki",
        "portainer", "dozzle", "vaultwarden", "minor-console",
        "uptime-kuma", "kibana", "rabbitmq-mgmt", "netdata",
        "wheeler-state-api", "repo-router-health"
      ]
    },
    "hostinger": {
      "description": "Hostinger routes (0.0.0.0 bound, internet-facing)",
      "routes": [
        "frgcrm-frontend", "frgcrm-api", "frgcrm-websocket",
        "openclaw-dashboard", "openclaw-api",
        "revenue-automation", "revenue-automation-webhook",
        "revenue-automation-cron", "revenue-automation-metrics",
        "hostinger-admin", "speedtest-tracker"
      ]
    },
    "tailscale": {
      "description": "Tailscale routes (tailnet-only, TLS required)",
      "routes": [
        "tailscale-gateway-aiops", "tailscale-gateway-coredb",
        "tailscale-mesh", "tailscale-metrics"
      ]
    },
    "coredb": {
      "description": "Core DB routes (tailnet-only, TLS required)",
      "routes": [
        "coredb-pgadmin", "coredb-pgbouncer-metrics"
      ]
    }
  },
  "enforcement_rules": [
    { "rule": "no_route_conflicts", "severity": "blocker" },
    { "rule": "auth_on_external_routes", "severity": "blocker" },
    { "rule": "rate_limit_protected", "severity": "high" },
    { "rule": "health_endpoint_required", "severity": "medium" }
  ]
}
