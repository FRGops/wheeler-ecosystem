# =============================================================================
# Wheeler Deployment System — Environment Variable Template
# =============================================================================
# This file is the SINGLE SOURCE OF TRUTH for all environment variable names.
# Each service gets its own .env.{service}.{environment} file derived from this.
#
# CATEGORIES:
#   [REQUIRED]   — Must be set or deployment fails
#   [SECRET]     — Must come from secrets manager, never hardcoded
#   [OPTIONAL]   — Has a safe default
#   [FEATURE]    — Feature flag, safe to toggle
#   [DEPLOY]     — Deployment-specific, changes per release
# =============================================================================

# =============================================================================
# SERVER IDENTITY
# =============================================================================
NODE_ROLE=edge                     # [REQUIRED] edge | aiops | coredb
NODE_ENV=production                # [REQUIRED] production | staging | development
SERVER_IP=                         # [DEPLOY] Server public IP
SERVER_HOSTNAME=                   # [DEPLOY] Server hostname

# =============================================================================
# DATABASE — COREDB NODE (5.78.210.123)
# =============================================================================
# WARNING: DO NOT define DATABASE_URL in service env files.
# Use the per-database variables below. The connection string is assembled
# by the application from these components at startup.
DATABASE_HOST=                     # [REQUIRED] COREDB host
DATABASE_PORT=5432                 # [REQUIRED] PostgreSQL port
DATABASE_NAME=wheeler              # [REQUIRED] Primary database name
DATABASE_USER=                     # [REQUIRED] [SECRET] Database user
DATABASE_PASSWORD=                 # [REQUIRED] [SECRET] Database password
DATABASE_POOL_MIN=2                # [OPTIONAL] Min connection pool size
DATABASE_POOL_MAX=20               # [OPTIONAL] Max connection pool size
DATABASE_SSL=true                  # [OPTIONAL] Enforce SSL connection
DATABASE_CA_CERT=                  # [OPTIONAL] CA certificate path for SSL

# Per-service database names (if using separate DBs)
DATABASE_NAME_API=wheeler_api      # [OPTIONAL] API service database
DATABASE_NAME_WORKERS=wheeler_workers # [OPTIONAL] Worker service database
DATABASE_NAME_LOGS=wheeler_logs    # [OPTIONAL] Logging database

# =============================================================================
# REDIS — COREDB NODE (5.78.210.123)
# =============================================================================
REDIS_HOST=                        # [REQUIRED] COREDB host
REDIS_PORT=6379                    # [REQUIRED] Redis port
REDIS_PASSWORD=                    # [OPTIONAL] [SECRET] Redis password
REDIS_DB=0                         # [OPTIONAL] Redis database number
REDIS_PREFIX=wheeler:              # [OPTIONAL] Key prefix for namespacing
REDIS_MAX_RETRIES=3                # [OPTIONAL] Connection retry attempts

# =============================================================================
# MINIO / OBJECT STORAGE — COREDB NODE (5.78.210.123)
# =============================================================================
MINIO_ENDPOINT=                    # [REQUIRED] MinIO server:port
MINIO_ACCESS_KEY=                  # [REQUIRED] [SECRET] MinIO access key
MINIO_SECRET_KEY=                  # [REQUIRED] [SECRET] MinIO secret key
MINIO_BUCKET=wheeler               # [REQUIRED] Default bucket name
MINIO_USE_SSL=true                 # [OPTIONAL] Use SSL for MinIO
MINIO_REGION=us-east-1             # [OPTIONAL] MinIO region

# =============================================================================
# AI SERVICES — AIOPS NODE (5.78.140.118)
# =============================================================================
# LiteLLM Proxy
LITELLM_ENDPOINT=                  # [REQUIRED] LiteLLM proxy URL
LITELLM_API_KEY=                   # [REQUIRED] [SECRET] LiteLLM API key
LITELLM_MASTER_KEY=                # [REQUIRED] [SECRET] LiteLLM master key

# DeepSeek
DEEPSEEK_API_KEY=                  # [REQUIRED] [SECRET] DeepSeek API key
DEEPSEEK_BASE_URL=                 # [OPTIONAL] DeepSeek base URL override
DEEPSEEK_MODEL=deepseek-chat       # [OPTIONAL] Default DeepSeek model
DEEPSEEK_TIMEOUT_MS=60000          # [OPTIONAL] Request timeout in ms
DEEPSEEK_MAX_RETRIES=3             # [OPTIONAL] Max retry attempts
DEEPSEEK_MAX_TOKENS=8192           # [OPTIONAL] Max tokens per request

# OpenRouter (fallback)
OPENROUTER_API_KEY=                # [REQUIRED] [SECRET] OpenRouter API key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1 # [OPTIONAL]
OPENROUTER_TIMEOUT_MS=45000        # [OPTIONAL] Request timeout
OPENROUTER_MAX_RETRIES=2           # [OPTIONAL] Max retry attempts

# Model Fallback Configuration
AI_FALLBACK_ORDER=deepseek,openrouter # [OPTIONAL] Fallback priority order
AI_HEALTH_CHECK_INTERVAL_MS=30000  # [OPTIONAL] Model health check interval
AI_CIRCUIT_BREAKER_THRESHOLD=5     # [OPTIONAL] Failures before circuit open
AI_CIRCUIT_BREAKER_TIMEOUT_MS=60000 # [OPTIONAL] Circuit breaker cooldown

# =============================================================================
# ROUTING — EDGE NODE (187.77.148.88)
# =============================================================================
DOMAIN=                             # [REQUIRED] Primary domain
TRAEFIK_API_PORT=8080               # [OPTIONAL] Traefik dashboard/API port
TRAEFIK_ENTRYPOINT_HTTP=80          # [OPTIONAL] HTTP entrypoint port
TRAEFIK_ENTRYPOINT_HTTPS=443        # [OPTIONAL] HTTPS entrypoint port
TRAEFIK_ACME_EMAIL=                 # [REQUIRED] Let's Encrypt email
TRAEFIK_LOG_LEVEL=INFO              # [OPTIONAL] ERROR | WARN | INFO | DEBUG

# SSL
SSL_CERT_PATH=/etc/letsencrypt/live/${DOMAIN}/fullchain.pem  # [DEPLOY]
SSL_KEY_PATH=/etc/letsencrypt/live/${DOMAIN}/privkey.pem     # [DEPLOY]
SSL_MIN_VERSION=TLSv1.2            # [OPTIONAL] Minimum TLS version

# =============================================================================
# PM2 RUNTIME — AIOPS NODE
# =============================================================================
PM2_HOME=~/.pm2                    # [DEPLOY] PM2 home directory
PM2_PUBLIC_KEY=                    # [OPTIONAL] PM2 monitoring public key
PM2_SECRET_KEY=                    # [OPTIONAL] [SECRET] PM2 monitoring secret key
PM2_LOG_MAX_SIZE=10M               # [OPTIONAL] Max log file size
PM2_LOG_RETAIN_COUNT=30            # [OPTIONAL] Number of rotated logs to keep

# =============================================================================
# DOCKER RUNTIME — ALL NODES
# =============================================================================
DOCKER_REGISTRY=                   # [REQUIRED] Docker image registry URL
DOCKER_REGISTRY_USER=              # [OPTIONAL] Registry username
DOCKER_REGISTRY_PASSWORD=          # [OPTIONAL] [SECRET] Registry password
DOCKER_LOG_MAX_SIZE=10m            # [OPTIONAL] Max container log size
DOCKER_LOG_MAX_FILE=3              # [OPTIONAL] Max rotated log files
DOCKER_NETWORK_FRONTEND=wheeler-frontend  # [OPTIONAL] Frontend network name
DOCKER_NETWORK_BACKEND=wheeler-backend    # [OPTIONAL] Backend network name

# =============================================================================
# OBSERVABILITY
# =============================================================================
LOG_LEVEL=info                     # [OPTIONAL] debug | info | warn | error
METRICS_PORT=9090                  # [OPTIONAL] Prometheus metrics port
METRICS_ENABLED=true               # [OPTIONAL] Enable metrics collection

# Health Check
HEALTH_CHECK_PORT=                  # [DEPLOY] Health endpoint port
HEALTH_CHECK_PATH=/health           # [DEPLOY] Health endpoint path
HEALTH_CHECK_TIMEOUT_MS=5000        # [OPTIONAL] Health check timeout

# Alerting (placeholders — configure when alerting is set up)
ALERT_WEBHOOK_URL=                  # [OPTIONAL] [SECRET] Alert webhook URL
ALERT_SLACK_CHANNEL=                # [OPTIONAL] Slack alert channel
ALERT_EMAIL=                        # [OPTIONAL] Alert email address

# =============================================================================
# DEPLOYMENT METADATA
# =============================================================================
DEPLOY_VERSION=                     # [DEPLOY] Current deploy version/commit
DEPLOY_TIMESTAMP=                   # [DEPLOY] ISO 8601 deploy timestamp
DEPLOY_ENVIRONMENT=production       # [DEPLOY] Deployment target environment
DEPLOY_BY=                          # [DEPLOY] Who/what triggered the deploy
DEPLOY_ID=                          # [DEPLOY] Unique deployment identifier

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_ENABLE_CANARY=false         # [FEATURE] Enable canary deployments
FEATURE_ENABLE_AUTO_ROLLBACK=true   # [FEATURE] Auto-rollback on health failure
FEATURE_ENABLE_BACKUP_BEFORE_DEPLOY=true # [FEATURE] Mandatory pre-deploy backup
FEATURE_ENABLE_MAINTENANCE_MODE=false   # [FEATURE] Maintenance mode toggle
FEATURE_ENABLE_READ_ONLY_DB=false   # [FEATURE] Read-only DB mode for maintenance

# =============================================================================
# VALIDATION RULES (enforced by preflight-check.sh)
# =============================================================================
# 1. Every [REQUIRED] var must be set (non-empty)
# 2. Every [SECRET] var must NOT be a default/placeholder value
# 3. No duplicate DATABASE_URL — use DATABASE_HOST/DATABASE_PORT/etc.
# 4. URLs must be valid and reachable (validated at deploy time)
# 5. Port numbers must be in valid range (1-65535)
# 6. Environment must be one of: production, staging, development
# 7. NODE_ROLE must be one of: edge, aiops, coredb
