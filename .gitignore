# Secrets — never commit .env files
.env
*.env
.env.*

# Shell state
.bash_history
.bashrc

# Cache dirs
.cache/
.claude/cache/
.claude/paste-cache/
.claude/plugins/cache/

# Session transcripts (large, ephemeral)
.claude/projects/-root/*.jsonl
.claude/projects/-root/[0-9a-f]*-[0-9a-f]*-[0-9a-f]*-[0-9a-f]*-[0-9a-f]*/
.claude/projects/-root/[0-9a-f]*-[0-9a-f]*-[0-9a-f]*-[0-9a-f]*-[0-9a-f]*.jsonl

# Backups
.claude/backups/

# File history
.claude/file-history/
.claude/history.jsonl

# Session data (ephemeral)
.claude/sessions/
.claude/shell-snapshots/
.claude/tasks/
.ai/reports/sessions/

# Credentials and auth
.claude/.credentials.json
.claude/mcp-needs-auth-cache.json

# Plans (ephemeral)
.claude/plans/

# Plugin cache
.claude/plugins/plugin-catalog-cache.json

# Security warning state
.claude/security_warnings_state_*.json

# External tool configs / state
.config/
.docker/
.local/
.npm/
.semgrep/
.ai/repo-drop-zone.txt
.ai/repo-processed.txt

# SSH keys and PM2 state (never commit)
.ssh/
.pm2/
backups/
