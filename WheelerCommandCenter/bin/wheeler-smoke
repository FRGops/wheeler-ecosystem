#!/usr/bin/env bash
# ============================================
# wheeler-smoke — Smoke tests for apps
# ============================================
set -euo pipefail

TARGET="${1:-}"

ok()  { echo "  [OK]    $1"; }
warn(){ echo "  [WARN]  $1"; }
fail(){ echo "  [FAIL]  $1"; }

usage() {
  echo "Usage: wheeler smoke <app|all>"
  echo ""
  echo "  all          — Smoke test all configured domains"
  echo "  frg          — Funds Recovery Group"
  echo "  frgops       — FRG Ops"
  echo "  surplusai    — SurplusAI"
  echo "  predictionradar — Prediction Radar"
  echo "  brain        — Wheeler Brain OS"
  echo "  aiops        — AIops control plane"
}

smoke_url() {
  local name="$1"
  local url="$2"
  echo -n "  $name ($url): "
  local code
  code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 10 -L "$url" 2>/dev/null || echo "000")
  if [ "$code" = "200" ]; then
    ok "HTTP $code"
  elif [ "$code" = "000" ]; then
    fail "unreachable"
  else
    warn "HTTP $code"
  fi
}

smoke_all() {
  echo ""
  echo " ═══ SMOKE TEST: ALL APPS ═══"
  echo ""

  echo " --- Public Domains ---"
  smoke_url "FRG"           "https://fundsrecoverygroup.com"
  smoke_url "FRG (www)"     "https://www.fundsrecoverygroup.com"
  smoke_url "Horizon Fed"   "https://horizonfederalservices.com"
  smoke_url "PredictionRad" "https://predictionradar.app"

  echo ""
  echo " --- Internal Services ---"
  smoke_url "AIops Dashboard" "http://localhost:8180"
  smoke_url "Uptime Kuma"     "http://localhost:3001"
  smoke_url "Grafana"         "http://localhost:3002"
  smoke_url "Netdata"         "http://localhost:19999"
  smoke_url "LiteLLM"         "http://localhost:4049"
  smoke_url "Prometheus"      "http://localhost:9090"

  echo ""
  echo " --- Docker Containers ---"
  if command -v docker &>/dev/null; then
    local total unhealthy
    total=$(docker ps -q 2>/dev/null | wc -l)
    unhealthy=$(docker ps --filter "health=unhealthy" -q 2>/dev/null | wc -l)
    ok "$total containers running"
    if [ "$unhealthy" -gt 0 ]; then
      fail "$unhealthy unhealthy containers"
    fi
  fi

  echo ""
  echo "Smoke test complete. Report saved to: $WHEELER_HOME/reports/"
  echo "Run 'wheeler health' for deeper diagnostics."
}

if [ -z "$TARGET" ]; then
  usage
  exit 1
fi

case "$TARGET" in
  all)   smoke_all ;;
  frg)   smoke_url "FRG" "https://fundsrecoverygroup.com" ;;
  frgops)
    echo "FRGops smoke test: TODO — configure endpoint in config/services.yml"
    ;;
  surplusai)
    echo "SurplusAI smoke test: TODO — configure endpoint in config/services.yml"
    ;;
  predictionradar)
    smoke_url "PredictionRadar" "https://predictionradar.app"
    ;;
  brain)
    smoke_url "Brain OS" "http://localhost:8180"
    ;;
  aiops)
    smoke_url "AIops" "http://localhost:8180"
    smoke_url "Grafana" "http://localhost:3002"
    smoke_url "LiteLLM" "http://localhost:4049"
    ;;
  *)
    usage
    exit 1
    ;;
esac
